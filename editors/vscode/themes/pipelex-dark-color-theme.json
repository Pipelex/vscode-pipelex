{
  "$schema": "vscode://schemas/color-theme",
  "name": "Pipelex Dark",
  "type": "dark",
  "colors": {},
  "tokenColors": [
    {
      "name": "MTHDS Pipe sections, pipe types, pipe names",
      "scope": [
        "entity.name.tag.pipe.mthds",
        "entity.name.tag.pipe-type.mthds",
        "entity.name.tag.pipe-name.mthds"
      ],
      "settings": {
        "foreground": "#FF6B6B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MTHDS Concept sections and types",
      "scope": "entity.name.type.concept.mthds",
      "settings": {
        "foreground": "#4ECDC4",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MTHDS Data variables",
      "scope": "variable.other.readwrite.mthds",
      "settings": {
        "foreground": "#98FB98",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MTHDS Model references",
      "scope": "constant.other.symbol.mthds",
      "settings": {
        "foreground": "#FFB86C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MTHDS Sigils and escape sequences",
      "scope": [
        "storage.modifier.mthds",
        "constant.character.escape.mthds"
      ],
      "settings": {
        "foreground": "#FF79C6"
      }
    },
    {
      "name": "MTHDS Pipe ref arrow",
      "scope": "keyword.operator.arrow.mthds",
      "settings": {
        "foreground": "#FF79C6"
      }
    },
    {
      "name": "MTHDS Namespace / package address",
      "scope": "punctuation.separator.namespace.mthds",
      "settings": {
        "foreground": "#7C7C9C"
      }
    },
    {
      "name": "MTHDS Jinja keywords",
      "scope": "keyword.control.jinja.mthds",
      "settings": {
        "foreground": "#FF79C6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MTHDS Jinja operators",
      "scope": "keyword.operator.jinja.mthds",
      "settings": {
        "foreground": "#FF79C6"
      }
    },
    {
      "name": "MTHDS HTML tags in templates",
      "scope": "entity.name.tag.html.mthds",
      "settings": {
        "foreground": "#FF79C6"
      }
    },
    {
      "name": "MTHDS Jinja delimiters",
      "scope": "punctuation.definition.jinja.mthds",
      "settings": {
        "foreground": "#FFB86C"
      }
    },
    {
      "name": "MTHDS Strings",
      "scope": [
        "string.quoted.triple.basic.block.mthds",
        "string.quoted.single.basic.line.mthds",
        "string.quoted.triple.literal.block.mthds",
        "string.quoted.single.literal.line.mthds",
        "string.quoted.triple.basic.block.jinja2.mthds",
        "string.quoted.single.basic.line.jinja2.mthds",
        "string.quoted.triple.basic.block.prompt.mthds",
        "string.quoted.single.basic.line.prompt.mthds",
        "string.quoted.html.mthds"
      ],
      "settings": {
        "foreground": "#ce9178"
      }
    },
    {
      "name": "MTHDS Comments",
      "scope": [
        "comment.line.number-sign.mthds",
        "comment.block.jinja.mthds",
        "comment.block.html.mthds"
      ],
      "settings": {
        "foreground": "#6a9955",
        "fontStyle": "italic"
      }
    },
    {
      "name": "MTHDS Preprocessor directives",
      "scope": "meta.preprocessor.mthds",
      "settings": {
        "foreground": "#6a9955",
        "fontStyle": "italic"
      }
    },
    {
      "name": "MTHDS Generic property names",
      "scope": "support.type.property-name.mthds",
      "settings": {
        "foreground": "#9cdcfe"
      }
    },
    {
      "name": "MTHDS Booleans",
      "scope": "constant.language.boolean.mthds",
      "settings": {
        "foreground": "#569cd6"
      }
    },
    {
      "name": "MTHDS Table/array property names",
      "scope": [
        "support.type.property-name.table.mthds",
        "support.type.property-name.array.mthds"
      ],
      "settings": {
        "foreground": "#9cdcfe"
      }
    },
    {
      "name": "MTHDS Jinja functions and HTML attributes",
      "scope": [
        "support.function.jinja.mthds",
        "entity.other.attribute-name.html.mthds"
      ],
      "settings": {
        "foreground": "#dcdcaa"
      }
    },
    {
      "name": "MTHDS Jinja variables",
      "scope": "variable.other.jinja.mthds",
      "settings": {
        "foreground": "#9cdcfe"
      }
    },
    {
      "name": "MTHDS Invalid escapes",
      "scope": "invalid.illegal.escape.mthds",
      "settings": {
        "foreground": "#FF5555",
        "fontStyle": "underline"
      }
    }
  ]
}
